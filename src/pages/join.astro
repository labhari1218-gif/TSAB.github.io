---
import CalloutPanel from "@/components/CalloutPanel.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import { siteConfig, withBase } from "@/lib/site";
---

<MainLayout title="Join TSAB">
  <section class="page-section">
    <div class="shell">
      <SectionIntro
        eyebrow="Join / Contact"
        title="A single public page for joining, contributing, submitting, and reaching out."
        copy="Keep all primary actions here so visitors can move from interest to participation without searching through the full site."
      />
      <div class="listing-grid two-up action-grid">
        <article class="card action-card">
          <h2>Join the main community</h2>
          <p>Use the primary community link or form when you are ready to become part of TSAB.</p>
          <a class="button primary" href={withBase(siteConfig.socialLinks[1]?.href ?? "#")}>Open Join Link</a>
        </article>
        <article class="card action-card">
          <h2>Volunteer with the team</h2>
          <p>Direct future volunteers toward the outreach, social media, and operations workflow here.</p>
          <a class="button secondary" href={withBase("https://example.com/tsab-volunteer-form")}>Volunteer Interest Form</a>
        </article>
        <article class="card action-card">
          <h2>Submit media or gallery updates</h2>
          <p>Use a public upload or collection form later. For now, replace this placeholder with the real process.</p>
          <a class="button secondary" href={withBase("https://example.com/tsab-media-form")}>Media Submission Link</a>
        </article>
        <article class="card action-card">
          <h2>Nominate an achiever</h2>
          <p>Use this action to collect future member stories and recognition submissions from the community.</p>
          <a class="button secondary" href={withBase("https://example.com/tsab-achiever-form")}>Nomination Form</a>
        </article>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="shell">
      <CalloutPanel
        eyebrow="Contact"
        title="Update placeholder forms and contact links as soon as TSAB finalizes them."
        copy={`The current placeholder contact email is ${siteConfig.email}. Replace it in src/lib/site.ts, then update the public links here and in the footer.`}
        primaryHref={`mailto:${siteConfig.email}`}
        primaryLabel="Email TSAB"
        secondaryHref="/working-groups/"
        secondaryLabel="See Working Groups"
      />
    </div>
  </section>
</MainLayout>

<style>
  .action-grid {
    margin-top: 2rem;
  }

  .action-card {
    padding: 1.5rem;
  }

  .action-card h2 {
    margin: 0 0 0.6rem;
    font-family: "Cormorant Garamond", serif;
    font-size: 1.9rem;
  }

  .action-card p {
    color: var(--color-muted);
  }
</style>
