---
import CalloutPanel from "@/components/CalloutPanel.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import { getSiteSettings } from "@/lib/settings";
import { isExternalHref, withBase } from "@/lib/site";

const settings = await getSiteSettings();
const directChannel =
  settings.socialLinks.find((link) => /forum|whatsapp/i.test(link.label)) ??
  settings.socialLinks[0] ?? { label: "See Working Groups", href: "/working-groups/" };
const contactCopy = settings.email
  ? `For direct queries, you can reach TSAB at ${settings.email}. You can also use the join and working-group links on this page to find the right pathway.`
  : "Use the public TSAB channels on this page to join the community, find the right working group, and stay connected.";
---

<MainLayout title="Join TSAB">
  <section class="page-section">
    <div class="shell">
      <SectionIntro
        eyebrow="Join / Contact"
        title="Joining TSAB is simple, warm, and easy to understand."
        copy="Whether you want to join the community, volunteer, submit media, or nominate an achiever, you can find the right next step here."
      />
      <div class="listing-grid two-up action-grid">
        {settings.joinActions.map((action, index) => (
          <article class="card action-card" data-spotlight data-tilt data-reveal data-reveal-delay={String(index > 2 ? 2 : index)}>
            <p class="action-label">{index === 0 ? "Start Here" : "Public Pathway"}</p>
            <h2>{action.title}</h2>
            <p>{action.description}</p>
            <a
              class:list={["button", index === 0 ? "primary" : "secondary"]}
              href={withBase(action.href)}
              data-magnetic
              target={isExternalHref(action.href) ? "_blank" : undefined}
              rel={isExternalHref(action.href) ? "noreferrer" : undefined}
            >
              {action.label}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="shell">
      <CalloutPanel
        eyebrow="Contact"
        title="Use the public contact channels to stay connected with TSAB."
        copy={contactCopy}
        primaryHref={settings.email ? `mailto:${settings.email}` : directChannel.href}
        primaryLabel={settings.email ? "Email TSAB" : directChannel.label}
        secondaryHref="/working-groups/"
        secondaryLabel="See Working Groups"
      />
    </div>
  </section>
</MainLayout>

<style>
  .action-grid {
    margin-top: 2rem;
  }

  .action-card {
    padding: 1.5rem;
  }

  .action-card h2 {
    margin: 0 0 0.6rem;
    font-family: "Cormorant Garamond", serif;
    font-size: 1.9rem;
  }

  .action-label {
    margin: 0 0 0.55rem;
    color: var(--color-brand);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .action-card p {
    color: var(--color-muted);
  }
</style>
