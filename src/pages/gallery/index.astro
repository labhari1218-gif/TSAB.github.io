---
import { getCollection } from "astro:content";
import EmptyState from "@/components/EmptyState.astro";
import GalleryAlbumCard from "@/components/GalleryAlbumCard.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import { sortByDateDesc } from "@/lib/utils";

const albums = sortByDateDesc(await getCollection("galleryAlbums"));
---

<MainLayout title="TSAB Gallery">
  <section class="page-section">
    <div class="shell">
      <SectionIntro
        eyebrow="Gallery"
        title="Gallery"
        copy="A collection of TSAB memories — celebrations, gatherings, shared moments, and the joy of being together. Every album tells the story of our community."
      />
    </div>
  </section>

  <section class="page-section compact">
    <div class="shell">
      {albums.length > 0 ? (
        <div class="listing-grid two-up">
          {albums.map((album) => <GalleryAlbumCard album={album} />)}
        </div>
      ) : (
        <EmptyState
          title="No gallery albums yet"
          copy="Gallery albums and community moments will appear here as TSAB memories are added."
        />
      )}
    </div>
  </section>
</MainLayout>
