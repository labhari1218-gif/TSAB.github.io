---
import { getCollection } from "astro:content";
import AchieverCard from "@/components/AchieverCard.astro";
import CalloutPanel from "@/components/CalloutPanel.astro";
import EventCard from "@/components/EventCard.astro";
import FeatureCard from "@/components/FeatureCard.astro";
import GalleryAlbumCard from "@/components/GalleryAlbumCard.astro";
import GroupCard from "@/components/GroupCard.astro";
import HeroSection from "@/components/HeroSection.astro";
import OpportunityCard from "@/components/OpportunityCard.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import { getSiteSettings } from "@/lib/settings";
import { withBase } from "@/lib/site";
import { sortByDateDesc } from "@/lib/utils";

const settings = await getSiteSettings();
const announcements = await getCollection("announcements");
const pinnedAnnouncement = sortByDateDesc(announcements.filter((item) => item.data.pinned))[0];
const upcomingEvents = sortByDateDesc(
  (await getCollection("events")).filter((item) => item.data.status === "upcoming")
);
const featuredEvent = upcomingEvents.find((item) => item.data.featured) ?? upcomingEvents[0];
const activeOpportunities = [...(await getCollection("opportunities")).filter((item) => item.data.isActive)].sort(
  (a, b) => {
    const aDate = new Date(a.data.deadline ?? 0).getTime();
    const bDate = new Date(b.data.deadline ?? 0).getTime();
    return aDate - bDate;
  }
);
const featuredOpportunity = activeOpportunities.find((item) => item.data.featured) ?? activeOpportunities[0];
const achievers = await getCollection("achievers");
const featuredAchiever = achievers.find((item) => item.data.featured) ?? achievers[0];
const featuredAlbums = sortByDateDesc(
  (await getCollection("galleryAlbums")).filter((item) => item.data.featured)
).slice(0, 2);
const groups = [...(await getCollection("groups"))].sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<MainLayout title="TSAB | Telugu Students Association Bhopal">
  <HeroSection />

  {pinnedAnnouncement && (
    <section class="page-section compact">
      <div class="shell">
        <div class="surface-panel ambient-grid" data-spotlight data-reveal>
          <div class="eyebrow">Pinned Update</div>
          <h2 class="panel-title">{pinnedAnnouncement.data.title}</h2>
          <p class="panel-copy">{pinnedAnnouncement.data.summary}</p>
          {pinnedAnnouncement.data.ctaLabel && pinnedAnnouncement.data.ctaUrl && (
            <a class="button secondary" href={withBase(pinnedAnnouncement.data.ctaUrl)} data-magnetic>{pinnedAnnouncement.data.ctaLabel}</a>
          )}
        </div>
      </div>
    </section>
  )}

  <section class="page-section">
    <div class="shell">
      <SectionIntro
        eyebrow="What TSAB Offers"
        title="A warm, simple space built around what Telugu students actually need."
        copy="TSAB is here to help students feel connected, stay informed, celebrate culture, and grow together through a stronger student network."
      />
      <div class="listing-grid four-up feature-grid">
        {settings.homeThemes.map((card, index) => <FeatureCard {...card} index={index} />)}
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="shell">
      <SectionIntro
        eyebrow="Spotlight"
        title="What the community can join, explore, and celebrate right now."
        copy="TSAB highlights the next thing to attend, the next opportunity worth opening, and the student stories that deserve visibility."
      />
      <div class="listing-grid three-up spotlight-grid">
        {featuredEvent && <EventCard event={featuredEvent} />}
        {featuredOpportunity && <OpportunityCard opportunity={featuredOpportunity} />}
        {featuredAchiever && <AchieverCard achiever={featuredAchiever} />}
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="shell split-about">
      <div class="about-intro-shell">
        <SectionIntro
          eyebrow="About TSAB"
          title={settings.aboutIntro.title}
          copy={settings.aboutIntro.body[0]}
        />
      </div>
      <div class="card values-card ambient-grid" data-spotlight data-tilt data-reveal data-reveal-delay="1">
        <p class="about-accent">{settings.aboutIntro.accentTe}</p>
        <ul>
          {settings.aboutMissionPoints.map((value) => <li>{value}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="shell">
      <SectionIntro
        eyebrow="Gallery Preview"
        title="Memories deserve a clean archive, not a cluttered feed."
        copy="Albums help TSAB preserve festivals, gatherings, service moments, and community milestones in a way that stays easy to browse later."
      />
      <div class="listing-grid two-up gallery-preview-grid">
        {featuredAlbums.map((album) => <GalleryAlbumCard album={album} />)}
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="shell">
      <SectionIntro
        eyebrow="Working Groups"
        title="Four clear pathways into the TSAB community."
        copy="The public site should show how TSAB works: one space for belonging, one for opportunities, one for volunteers, and one for media memories."
      />
      <div class="listing-grid two-up pathways-grid">
        {groups.map((group) => <GroupCard group={group} />)}
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="shell">
      <CalloutPanel
        eyebrow="Join TSAB"
        title="Belonging should feel simple, human, and easy to begin."
        copy="Join TSAB to find people, celebrate Telugu culture, share opportunities, and become part of a student support system away from home."
        primaryHref="/join/"
        primaryLabel="Open Join & Contact"
        secondaryHref="/about/"
        secondaryLabel="Learn About TSAB"
      />
    </div>
  </section>
</MainLayout>

<style>
  .panel-title {
    margin: 0.85rem 0 0;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 0.96;
  }

  .panel-copy {
    max-width: 60ch;
    color: var(--color-muted);
  }

  .feature-grid {
    margin-top: 2rem;
  }

  .spotlight-grid,
  .gallery-preview-grid,
  .pathways-grid {
    position: relative;
  }

  .split-about {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .values-card {
    padding: 1.5rem;
  }

  .about-accent {
    margin: 0 0 0.8rem;
    color: var(--color-brand);
    font-weight: 700;
  }

  .values-card ul {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--color-muted);
  }

  .values-card li + li {
    margin-top: 0.9rem;
  }

  @media (min-width: 880px) {
    .split-about {
      grid-template-columns: 1.1fr 0.9fr;
    }

    .feature-grid > :first-child {
      grid-column: span 2;
      min-height: 21rem;
    }
  }
</style>
