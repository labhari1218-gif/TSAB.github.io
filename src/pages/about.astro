---
import CalloutPanel from "@/components/CalloutPanel.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import { getSiteSettings } from "@/lib/settings";

const settings = await getSiteSettings();
---

<MainLayout title="About TSAB">
  <section class="page-section">
    <div class="shell split-hero">
      <div class="surface-panel ambient-grid" data-spotlight data-reveal>
        <div class="eyebrow">{settings.aboutIntro.eyebrow}</div>
        <h1>{settings.aboutIntro.title}</h1>
        <p class="accent-te">{settings.aboutIntro.accentTe}</p>
        {settings.aboutIntro.body.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <div class="card timeline-card ambient-grid" data-spotlight data-tilt data-reveal data-reveal-delay="1">
        <p class="eyebrow">Mission</p>
        <ol>
          {settings.aboutMissionPoints.map((point) => <li>{point}</li>)}
        </ol>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="shell">
      <SectionIntro
        eyebrow="Mission"
        title="Our Mission"
        copy="TSAB is a student-led community for Telugu students in Bhopal. It exists to help students feel connected, supported, and represented while building a strong network across campuses and institutions."
      />
      <div class="listing-grid two-up about-grid">
        <article class="card prose-panel" data-spotlight data-tilt data-reveal>
          <h2>{settings.aboutIntro.whoCanJoinTitle}</h2>
          <p>{settings.aboutIntro.whoCanJoinBody}</p>
        </article>
        <article class="card prose-panel" data-spotlight data-tilt data-reveal data-reveal-delay="1">
          <h2>{settings.aboutIntro.familiarSpaceTitle}</h2>
          <p>{settings.aboutIntro.familiarSpaceBody}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="shell">
      <div class="listing-grid three-up">
        <article class="card pillar-card" data-spotlight data-tilt data-reveal>
          <h2>Belonging</h2>
          <p>TSAB is built around people, connection, and a shared sense of belonging.</p>
        </article>
        <article class="card pillar-card" data-spotlight data-tilt data-reveal data-reveal-delay="1">
          <h2>Growth</h2>
          <p>Opportunities, achiever stories, and student support help the whole community move forward.</p>
        </article>
        <article class="card pillar-card" data-spotlight data-tilt data-reveal data-reveal-delay="2">
          <h2>Culture</h2>
          <p>Telugu culture, language, and tradition remain an important part of what brings TSAB together.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="shell">
      <CalloutPanel
        eyebrow="Next Step"
        title="TSAB is more than a group."
        copy="For many members, it becomes a familiar space away from home."
        primaryHref="/join/"
        primaryLabel="Join TSAB"
        secondaryHref="/team/"
        secondaryLabel="Meet the Team"
      />
    </div>
  </section>
</MainLayout>

<style>
  h1 {
    margin: 0.8rem 0 0;
    max-width: 12ch;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2.9rem, 6vw, 5rem);
    line-height: 0.92;
  }

  p,
  li {
    color: var(--color-muted);
  }

  .accent-te {
    margin: 0.35rem 0 1rem;
    color: var(--color-brand);
    font-weight: 700;
  }

  .timeline-card,
  .prose-panel,
  .pillar-card {
    padding: 1.5rem;
  }

  ol,
  ul {
    margin: 1rem 0 0;
    padding-left: 1.2rem;
  }

  .pillar-card h2,
  .prose-panel h2 {
    margin: 0 0 0.6rem;
    font-family: "Cormorant Garamond", serif;
    font-size: 1.9rem;
  }
</style>
