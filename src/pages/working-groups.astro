---
import { getCollection } from "astro:content";
import GroupCard from "@/components/GroupCard.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import MainLayout from "@/layouts/MainLayout.astro";

const groups = [...(await getCollection("groups"))].sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<MainLayout title="TSAB Working Groups">
  <section class="page-section">
    <div class="shell">
      <SectionIntro
        eyebrow="Working Groups"
        title="TSAB works best when every public pathway is easy to understand."
        copy="These four groups show how the community stays connected, shares opportunities, runs public communication, and preserves memories without exposing internal chats."
      />
    </div>
  </section>

  <section class="page-section compact">
    <div class="shell">
      <div class="listing-grid two-up pathways-grid">
        {groups.map((group) => <GroupCard group={group} />)}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .pathways-grid {
    position: relative;
  }
</style>
