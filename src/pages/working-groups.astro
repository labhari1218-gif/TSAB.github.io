---
import { getCollection } from "astro:content";
import GroupCard from "@/components/GroupCard.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import MainLayout from "@/layouts/MainLayout.astro";

const groups = [...(await getCollection("groups"))].sort((a, b) => a.data.sortOrder - b.data.sortOrder);
---

<MainLayout title="TSAB Working Groups">
  <section class="page-section">
    <div class="shell">
      <SectionIntro
        eyebrow="Working Groups"
        title="Working Groups"
        copy="TSAB grows through student-led teams that help organize, communicate, and preserve the energy of the community."
      />
    </div>
  </section>

  <section class="page-section compact">
    <div class="shell">
      <div class="listing-grid two-up pathways-grid">
        {groups.map((group) => <GroupCard group={group} />)}
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .pathways-grid {
    position: relative;
  }
</style>
