---
import AmbientBackdrop from "@/components/AmbientBackdrop.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { getSiteSettings } from "@/lib/settings";
import { withBase } from "@/lib/site";
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const settings = await getSiteSettings();
const { title, description = settings.description } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={new URL(withBase(settings.logoPath), Astro.site)} />
  </head>
  <body>
    <AmbientBackdrop />
    <a class="sr-only" href="#main-content">Skip to content</a>
    <SiteHeader currentPath={currentPath} />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter />
    <script is:inline type="module" src={withBase("/scripts/site-motion.js")}></script>
  </body>
</html>
