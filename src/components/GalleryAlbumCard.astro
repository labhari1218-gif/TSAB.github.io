---
import StackedAlbumPreview from "@/components/StackedAlbumPreview.astro";
import { withBase } from "@/lib/site";
import { formatDate } from "@/lib/utils";

interface Props {
  album: {
    slug: string;
    data: {
      title: string;
      eventDate: string;
      coverImage: string;
      coverAlt?: string;
      summary: string;
      images: Array<{ src: string; alt: string }>;
    };
  };
}

const { album } = Astro.props;
---

<article class="card album-card" data-spotlight data-tilt data-reveal>
  <StackedAlbumPreview
    coverImage={album.data.coverImage}
    coverAlt={album.data.coverAlt}
    images={album.data.images}
    title={album.data.title}
  />
  <div class="content">
    <p class="meta">{formatDate(album.data.eventDate)} · {album.data.images.length} images</p>
    <h3><a href={withBase(`/gallery/${album.slug}/`)}>{album.data.title}</a></h3>
    <p>{album.data.summary}</p>
  </div>
</article>

<style>
  .album-card {
    overflow: hidden;
  }

  .content {
    padding: 0.2rem 1.3rem 1.35rem;
  }

  .meta {
    margin: 0 0 0.65rem;
    color: var(--color-brand);
    font-size: 0.88rem;
    font-weight: 600;
  }

  h3 {
    margin: 0;
    font-size: 1.45rem;
    font-family: "Cormorant Garamond", serif;
  }

  p:last-child {
    margin-bottom: 0;
    color: var(--color-muted);
  }
</style>
