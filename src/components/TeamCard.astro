---
import { isExternalHref, withBase } from "@/lib/site";

interface Props {
  member: {
    data: {
      name: string;
      role: string;
      photo?: string;
      bio: string;
      contactLabel?: string;
      contactUrl?: string;
    };
  };
}

const { member } = Astro.props;
const contactHref = member.data.contactUrl ? withBase(member.data.contactUrl) : undefined;
---

<article class="card team-card" data-spotlight data-tilt data-reveal>
  <img
    src={withBase(member.data.photo ?? "/images/team/team-placeholder.svg")}
    alt={member.data.photo ? `${member.data.name} portrait` : `${member.data.name} profile image`}
  />
  <div class="content">
    <h3>{member.data.name}</h3>
    <p class="role">{member.data.role}</p>
    <p>{member.data.bio}</p>
    {member.data.contactLabel && contactHref && (
      <a
        class="inline-link"
        href={contactHref}
        target={isExternalHref(contactHref) ? "_blank" : undefined}
        rel={isExternalHref(contactHref) ? "noreferrer" : undefined}
      >
        {member.data.contactLabel}
      </a>
    )}
  </div>
</article>

<style>
  .team-card {
    overflow: hidden;
  }

  img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-bottom: 1px solid rgba(21, 58, 120, 0.08);
    background: rgba(21, 58, 120, 0.1);
  }

  .content {
    padding: 1.25rem;
  }

  h3 {
    margin: 0;
    font-size: 1.38rem;
    font-family: "Cormorant Garamond", serif;
  }

  .role {
    margin: 0.25rem 0 0.7rem;
    color: var(--color-brand);
    font-weight: 700;
  }

  p:last-of-type {
    color: var(--color-muted);
  }

  .inline-link {
    color: var(--color-brand);
    font-weight: 700;
  }
</style>
