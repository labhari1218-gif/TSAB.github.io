---
import { withBase } from "@/lib/site";

interface Props {
  coverImage: string;
  coverAlt?: string;
  images: Array<{ src: string; alt: string }>;
  title: string;
}

const { coverImage, coverAlt, images, title } = Astro.props;
const previewImages = [coverImage, ...images.slice(0, 2).map((image) => image.src)];
---

<div class="stacked-preview" aria-hidden="true">
  {previewImages.map((src, index) => (
    <div class:list={["frame", index === 0 && "is-cover"]}>
      <img src={withBase(src)} alt={index === 0 ? coverAlt ?? `${title} cover` : ""} />
    </div>
  ))}
</div>

<style>
  .stacked-preview {
    position: relative;
    min-height: clamp(13rem, 32vw, 17rem);
    padding: 1rem 1rem 0.3rem;
  }

  .frame {
    position: absolute;
    inset: 0;
    width: min(100%, 92%);
    margin: 0 auto;
    border-radius: 1.45rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.45);
    box-shadow: 0 18px 28px rgba(9, 20, 43, 0.12);
    transform-origin: center;
  }

  .frame:nth-child(1) {
    transform: translate3d(0, 0, 0) rotate(-3deg);
    z-index: 3;
  }

  .frame:nth-child(2) {
    transform: translate3d(1.2rem, 0.9rem, 0) rotate(4deg);
    z-index: 2;
    opacity: 0.92;
  }

  .frame:nth-child(3) {
    transform: translate3d(-1rem, 1.7rem, 0) rotate(-6deg);
    z-index: 1;
    opacity: 0.84;
  }

  img {
    width: 100%;
    height: 100%;
    aspect-ratio: 5 / 4;
    object-fit: cover;
    background: linear-gradient(135deg, rgba(21, 58, 120, 0.26), rgba(214, 163, 58, 0.16));
  }
</style>
