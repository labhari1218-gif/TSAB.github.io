---
import { getSiteSettings } from "@/lib/settings";
import { navLinks, withBase, withoutBase } from "@/lib/site";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const normalizedPath = withoutBase(currentPath);
const settings = await getSiteSettings();
---

<header class="site-header">
  <div class="shell nav-shell">
    <a class="brand" href={withBase("/")}>
      <img src={withBase(settings.logoPath)} alt={`${settings.fullName} logo`} />
      <div class="brand-copy">
        <strong>{settings.name}</strong>
        <span class="full-name">{settings.fullName}</span>
        <small>{settings.headlineTe}</small>
      </div>
    </a>

    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="primary-nav">
      Menu
    </button>

    <nav id="primary-nav" class="nav-links" aria-label="Primary">
      {navLinks.map((link) => (
        <a
          href={withBase(link.href)}
          class:list={[normalizedPath === link.href && "active"]}
          aria-current={normalizedPath === link.href ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector(".menu-toggle");
  const nav = document.querySelector("#primary-nav");

  if (toggle instanceof HTMLButtonElement && nav instanceof HTMLElement) {
    toggle.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      nav.dataset.open = String(!expanded);
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(18px);
    background: rgba(251, 248, 241, 0.84);
    border-bottom: 1px solid rgba(21, 58, 120, 0.08);
  }

  .nav-shell {
    display: grid;
    grid-template-columns: auto auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    min-width: 0;
  }

  .brand img {
    width: 3rem;
    height: 3rem;
    border-radius: 0.75rem;
    object-fit: cover;
  }

  .brand strong,
  .brand span,
  .brand small {
    display: block;
  }

  .brand strong {
    color: var(--color-brand);
    font-size: 1.05rem;
  }

  .full-name {
    margin-top: 0.12rem;
    color: var(--color-brand-strong);
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .brand small {
    color: var(--color-muted);
    font-size: 0.72rem;
  }

  .menu-toggle {
    justify-self: end;
    padding: 0.7rem 1rem;
    border: 1px solid rgba(21, 58, 120, 0.14);
    border-radius: 999px;
    background: white;
    color: var(--color-brand);
    font: inherit;
    font-weight: 700;
  }

  .nav-links {
    grid-column: 1 / -1;
    display: none;
    gap: 0.4rem;
    padding-top: 0.2rem;
  }

  .nav-links[data-open="true"] {
    display: grid;
  }

  .nav-links a {
    padding: 0.85rem 1rem;
    border-radius: 999px;
    color: var(--color-muted);
    font-weight: 600;
  }

  .nav-links a.active,
  .nav-links a:hover,
  .nav-links a:focus-visible {
    background: rgba(21, 58, 120, 0.08);
    color: var(--color-brand);
  }

  @media (min-width: 980px) {
    .nav-shell {
      grid-template-columns: auto 1fr;
    }

    .menu-toggle {
      display: none;
    }

    .nav-links {
      grid-column: auto;
      display: flex;
      justify-content: end;
      align-items: center;
      flex-wrap: wrap;
      padding-top: 0;
    }
  }
</style>
