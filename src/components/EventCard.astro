---
import { withBase } from "@/lib/site";
import { formatDate } from "@/lib/utils";

interface Props {
  event: {
    slug: string;
    data: {
      title: string;
      date: string;
      location: string;
      summary: string;
      coverImage: string;
      coverAlt?: string;
      tags: string[];
      status: "upcoming" | "past";
    };
  };
}

const { event } = Astro.props;
---

<article class="card event-card" data-spotlight data-tilt data-reveal>
  <div class="media-shell">
    <img src={withBase(event.data.coverImage)} alt={event.data.coverAlt ?? `${event.data.title} cover image`} />
    <span class="status-tag">{event.data.status === "upcoming" ? "Upcoming" : "Archive"}</span>
  </div>
  <div class="content">
    <p class="meta">{formatDate(event.data.date)} · {event.data.location}</p>
    <h3><a href={withBase(`/events/${event.slug}/`)}>{event.data.title}</a></h3>
    <p>{event.data.summary}</p>
    <ul class="pill-list">
      {event.data.tags.map((tag) => <li>{tag}</li>)}
    </ul>
  </div>
</article>

<style>
  .event-card {
    overflow: hidden;
  }

  .media-shell {
    position: relative;
    padding: 0.85rem 0.85rem 0;
  }

  img {
    aspect-ratio: 16 / 10;
    width: 100%;
    object-fit: cover;
    border-radius: calc(var(--radius-md) - 8px);
    background: linear-gradient(135deg, rgba(21, 58, 120, 0.22), rgba(214, 163, 58, 0.18));
  }

  .status-tag {
    position: absolute;
    left: 1.45rem;
    bottom: 1rem;
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: rgba(12, 29, 61, 0.74);
    color: white;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    backdrop-filter: blur(10px);
  }

  .content {
    padding: 1.15rem 1.3rem 1.35rem;
  }

  .meta {
    margin: 0 0 0.65rem;
    color: var(--color-brand);
    font-size: 0.88rem;
    font-weight: 600;
  }

  h3 {
    margin: 0;
    font-size: 1.42rem;
    font-family: "Cormorant Garamond", serif;
  }

  h3 a {
    color: inherit;
  }

  p:last-child {
    color: var(--color-muted);
  }
</style>
