---
import { isExternalHref, withBase } from "@/lib/site";

interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
const resolvedHref = withBase(href);
const externalAttrs = isExternalHref(resolvedHref) ? { target: "_blank", rel: "noreferrer" } : {};
---

<a class="button primary" href={resolvedHref} data-magnetic {...externalAttrs}>{label}</a>
