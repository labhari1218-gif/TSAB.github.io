---
import { withBase } from "@/lib/site";

interface Props {
  achiever: {
    slug: string;
    data: {
      name: string;
      institute: string;
      achievementTitle: string;
      summary: string;
      photo: string;
    };
  };
}

const { achiever } = Astro.props;
---

<article class="card achiever-card">
  <img src={withBase(achiever.data.photo)} alt="" />
  <div class="content">
    <p class="meta">{achiever.data.institute}</p>
    <h3><a href={withBase(`/achievers/${achiever.slug}/`)}>{achiever.data.name}</a></h3>
    <p class="title">{achiever.data.achievementTitle}</p>
    <p>{achiever.data.summary}</p>
  </div>
</article>

<style>
  .achiever-card {
    overflow: hidden;
  }

  img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background: linear-gradient(145deg, rgba(21, 58, 120, 0.25), rgba(214, 163, 58, 0.18));
  }

  .content {
    padding: 1.35rem;
  }

  .meta,
  .title {
    color: var(--color-brand);
    font-weight: 600;
  }

  .meta {
    margin: 0 0 0.55rem;
    font-size: 0.88rem;
  }

  .title {
    margin: 0;
  }

  h3 {
    margin: 0;
    font-size: 1.35rem;
  }

  p:last-child {
    margin-bottom: 0;
    color: var(--color-muted);
  }
</style>
