---
import { navLinks, siteConfig, withBase } from "@/lib/site";
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <section>
      <p class="eyebrow">TSAB</p>
      <h2>{siteConfig.fullName}</h2>
      <p>{siteConfig.tagline}</p>
    </section>

    <section>
      <h3>Quick Links</h3>
      <ul>
        {navLinks.map((link) => (
          <li><a href={withBase(link.href)}>{link.label}</a></li>
        ))}
      </ul>
    </section>

    <section>
      <h3>Contact</h3>
      <p>
        <a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
      </p>
      <ul>
        {siteConfig.socialLinks.map((link) => (
          <li><a href={withBase(link.href)}>{link.label}</a></li>
        ))}
      </ul>
      <p class="note">Update these placeholder links in <code>src/lib/site.ts</code>.</p>
    </section>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    padding: 3rem 0;
    background: linear-gradient(180deg, rgba(13, 37, 83, 0.97), rgba(10, 24, 53, 1));
    color: rgba(255, 255, 255, 0.88);
  }

  .footer-grid {
    display: grid;
    gap: 2rem;
  }

  h2,
  h3 {
    margin: 0;
    font-family: "Cormorant Garamond", serif;
  }

  h2 {
    font-size: 2rem;
  }

  p,
  li,
  a {
    color: rgba(255, 255, 255, 0.78);
  }

  ul {
    padding: 0;
    margin: 1rem 0 0;
    list-style: none;
  }

  li + li {
    margin-top: 0.55rem;
  }

  .note {
    font-size: 0.9rem;
  }

  code {
    font-family: inherit;
    color: white;
  }

  @media (min-width: 900px) {
    .footer-grid {
      grid-template-columns: 1.25fr 0.75fr 0.85fr;
    }
  }
</style>
