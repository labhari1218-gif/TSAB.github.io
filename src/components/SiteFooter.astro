---
import { getSiteSettings } from "@/lib/settings";
import { navLinks, withBase } from "@/lib/site";

const settings = await getSiteSettings();
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <section>
      <p class="eyebrow">TSAB</p>
      <h2>{settings.fullName}</h2>
      <p>{settings.footerTaglineEn}</p>
      <p class="telugu-line">{settings.footerTaglineTe}</p>
    </section>

    <section>
      <h3>Quick Links</h3>
      <ul>
        {navLinks.map((link) => (
          <li><a href={withBase(link.href)}>{link.label}</a></li>
        ))}
      </ul>
    </section>

    <section>
      <h3>Contact</h3>
      <p>
        <a href={`mailto:${settings.email}`}>{settings.email}</a>
      </p>
      <ul>
        {settings.socialLinks.map((link) => (
          <li>
            <a href={withBase(link.href)}>{link.label}</a>
            {link.note && <span class="link-note">{link.note}</span>}
          </li>
        ))}
      </ul>
    </section>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    padding: 3rem 0;
    background: linear-gradient(180deg, rgba(13, 37, 83, 0.97), rgba(10, 24, 53, 1));
    color: rgba(255, 255, 255, 0.88);
  }

  .footer-grid {
    display: grid;
    gap: 2rem;
  }

  .footer-grid > section {
    display: grid;
    align-content: start;
    gap: 0.65rem;
  }

  h2,
  h3 {
    margin: 0;
    font-family: "Cormorant Garamond", serif;
  }

  h2 {
    font-size: 2rem;
  }

  p,
  li,
  a {
    color: rgba(255, 255, 255, 0.78);
  }

  ul {
    padding: 0;
    margin: 1rem 0 0;
    list-style: none;
  }

  li + li {
    margin-top: 0.55rem;
  }

  .telugu-line {
    margin-top: 0.4rem;
    color: rgba(255, 255, 255, 0.92);
    font-weight: 600;
  }

  .link-note {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.58);
  }

  @media (min-width: 900px) {
    .footer-grid {
      grid-template-columns: 1.25fr 0.75fr 0.85fr;
    }
  }
</style>
