---
import { getSiteSettings } from "@/lib/settings";
import { isExternalHref, navLinks, withBase } from "@/lib/site";

const settings = await getSiteSettings();
const contactFallback = settings.socialLinks[0] ?? { label: "Join TSAB", href: "/join/" };
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <section class="footer-brand card" data-spotlight data-reveal>
      <p class="eyebrow">TSAB</p>
      <h2>{settings.fullName}</h2>
      <p>{settings.footerTaglineEn}</p>
      <p class="telugu-line">{settings.footerTaglineTe}</p>
    </section>

    <section class="footer-links" data-reveal data-reveal-delay="1">
      <h3>Quick Links</h3>
      <ul>
        {navLinks.map((link) => (
          <li><a href={withBase(link.href)}>{link.label}</a></li>
        ))}
      </ul>
    </section>

    <section class="footer-links" data-reveal data-reveal-delay="2">
      <h3>Contact</h3>
      {settings.email ? (
        <p>
          <a href={`mailto:${settings.email}`}>{settings.email}</a>
        </p>
      ) : (
        <p>Use TSAB&apos;s public channels to stay connected and reach the community team.</p>
      )}
      <ul>
        {settings.socialLinks.map((link) => (
          <li>
            <a
              href={withBase(link.href)}
              target={isExternalHref(link.href) ? "_blank" : undefined}
              rel={isExternalHref(link.href) ? "noreferrer" : undefined}
            >
              {link.label}
            </a>
            {link.note && <span class="link-note">{link.note}</span>}
          </li>
        ))}
      </ul>
      {!settings.email && (
        <p class="contact-cta">
          <a href={withBase(contactFallback.href)}>Open {contactFallback.label}</a>
        </p>
      )}
    </section>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    margin-top: 6rem;
    padding: 3.6rem 0;
    background:
      radial-gradient(circle at top center, rgba(214, 163, 58, 0.14), transparent 28%),
      linear-gradient(180deg, rgba(13, 37, 83, 0.98), rgba(9, 24, 53, 1));
    color: rgba(255, 255, 255, 0.88);
  }

  .footer-grid {
    display: grid;
    gap: 1.4rem;
  }

  .footer-grid > section {
    display: grid;
    align-content: start;
    gap: 0.7rem;
  }

  .footer-brand,
  .footer-links {
    position: relative;
    padding: 1.45rem;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(18px);
  }

  h2, h3 {
    margin: 0;
    font-family: "Cormorant Garamond", serif;
  }

  h2 {
    font-size: 2.3rem;
  }

  p,
  li,
  a {
    color: rgba(255, 255, 255, 0.78);
  }

  ul {
    padding: 0;
    margin: 1rem 0 0;
    list-style: none;
  }

  li + li {
    margin-top: 0.55rem;
  }

  .telugu-line {
    margin-top: 0.4rem;
    color: rgba(255, 255, 255, 0.92);
    font-weight: 600;
  }

  .link-note {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.58);
  }

  .contact-cta {
    margin-top: 1rem;
  }

  .contact-cta a {
    color: rgba(255, 255, 255, 0.94);
    font-weight: 700;
  }

  @media (min-width: 900px) {
    .footer-grid {
      grid-template-columns: 1.2fr 0.75fr 0.85fr;
    }
  }
</style>
