---
import { isExternalHref, withBase } from "@/lib/site";

interface Props {
  eyebrow: string;
  title: string;
  copy: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow,
  title,
  copy,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel
} = Astro.props;
const primaryResolvedHref = withBase(primaryHref);
const primaryExternalAttrs = isExternalHref(primaryResolvedHref) ? { target: "_blank", rel: "noreferrer" } : {};
const secondaryResolvedHref = secondaryHref ? withBase(secondaryHref) : undefined;
const secondaryExternalAttrs =
  secondaryResolvedHref && isExternalHref(secondaryResolvedHref) ? { target: "_blank", rel: "noreferrer" } : {};
---

<section class="surface-panel callout-panel ambient-grid" data-spotlight data-reveal data-tilt>
  <div class="eyebrow">{eyebrow}</div>
  <h2>{title}</h2>
  <p>{copy}</p>
  <div class="actions">
    <a class="button primary" href={primaryResolvedHref} data-magnetic {...primaryExternalAttrs}>{primaryLabel}</a>
    {secondaryHref && secondaryLabel && (
      <a class="button secondary" href={secondaryResolvedHref} data-magnetic {...secondaryExternalAttrs}>{secondaryLabel}</a>
    )}
  </div>
</section>

<style>
  .callout-panel h2 {
    margin: 0.9rem 0 0;
    max-width: 14ch;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 0.95;
  }

  .callout-panel p {
    max-width: 56ch;
    color: var(--color-muted);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.25rem;
  }
</style>
