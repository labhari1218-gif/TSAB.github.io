---
import PrimaryButton from "@/components/PrimaryButton.astro";
import SecondaryButton from "@/components/SecondaryButton.astro";
import { getSiteSettings } from "@/lib/settings";
import { withBase } from "@/lib/site";

const settings = await getSiteSettings();
---

<section class="page-section compact">
  <div class="shell split-hero">
    <div class="hero-copy surface-panel reveal">
      <div class="eyebrow">Telugu Student Community</div>
      <h1>{settings.headlineEn}</h1>
      <p class="headline-te">{settings.headlineTe}</p>
      <p>{settings.heroSupportingText}</p>
      <div class="mission-strip">
        <span>{settings.missionStripEn}</span>
        <strong>{settings.missionStripTe}</strong>
      </div>
      <div class="actions">
        <PrimaryButton href={settings.primaryCtas.join.href} label={settings.primaryCtas.join.label} />
        <SecondaryButton href={settings.primaryCtas.events.href} label={settings.primaryCtas.events.label} />
        <SecondaryButton
          href={settings.primaryCtas.opportunities.href}
          label={settings.primaryCtas.opportunities.label}
        />
      </div>
    </div>

    <aside class="wordmark card reveal stagger-1">
      <p class="label">Together we belong</p>
      <img src={withBase(settings.logoPath)} alt={`${settings.fullName} logo`} />
      <h2>{settings.name}</h2>
      <p class="subhead">{settings.fullName}</p>
      <p class="brand-te">{settings.headlineTe}</p>
      <p class="description">{settings.taglineEn}</p>
    </aside>
  </div>
</section>

<style>
  h1 {
    margin: 1rem 0 0;
    max-width: 10ch;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(3.2rem, 7vw, 6.1rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
  }

  .hero-copy p {
    max-width: 58ch;
    margin-bottom: 0;
    color: var(--color-muted);
    font-size: 1.06rem;
  }

  .headline-te {
    margin-top: 0.45rem;
    color: var(--color-brand);
    font-size: 1.15rem;
    font-weight: 700;
  }

  .mission-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.1rem;
    align-items: center;
    margin-top: 1.3rem;
    padding: 0.9rem 1rem;
    border-radius: 1.25rem;
    background: rgba(21, 58, 120, 0.08);
  }

  .mission-strip span {
    color: var(--color-brand);
    font-weight: 700;
  }

  .mission-strip strong {
    color: var(--color-accent);
    font-size: 1.02rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.4rem;
  }

  .wordmark {
    display: grid;
    align-content: start;
    gap: 0.75rem;
    padding: 1.5rem;
    background:
      radial-gradient(circle at top right, rgba(214, 163, 58, 0.18), transparent 28%),
      linear-gradient(180deg, rgba(21, 58, 120, 0.05), rgba(255, 255, 255, 0.96));
  }

  .label {
    margin: 0;
    color: var(--color-brand);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .wordmark img {
    width: 5rem;
    height: 5rem;
    object-fit: cover;
    border-radius: 1.1rem;
    box-shadow: 0 12px 28px rgba(13, 37, 83, 0.16);
  }

  .wordmark h2 {
    margin: 0;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2.8rem, 8vw, 4.4rem);
    line-height: 0.9;
    color: var(--color-brand);
  }

  .subhead {
    margin: 0;
    font-weight: 700;
  }

  .brand-te {
    margin: 0;
    color: var(--color-brand);
    font-weight: 700;
  }

  .description {
    margin: 0;
    color: var(--color-muted);
  }
</style>
