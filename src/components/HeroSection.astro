---
import PrimaryButton from "@/components/PrimaryButton.astro";
import SecondaryButton from "@/components/SecondaryButton.astro";
import { getSiteSettings } from "@/lib/settings";
import { withBase } from "@/lib/site";

const settings = await getSiteSettings();
const themeTags = settings.homeThemes.map((theme) => theme.title).slice(0, 4);
---

<section class="page-section compact">
  <div class="shell split-hero hero-shell">
    <div class="hero-copy surface-panel ambient-grid" data-spotlight data-reveal>
      <div class="hero-noise"></div>
      <div class="eyebrow">{settings.fullName}</div>
      <h1>{settings.headlineEn}</h1>
      <p class="association-line">{settings.fullName}</p>
      <p class="headline-te">{settings.taglineTe}</p>
      <p>{settings.heroSupportingText}</p>
      <ul class="hero-tags">
        {themeTags.map((tag) => <li>{tag}</li>)}
      </ul>
      <div class="actions">
        <PrimaryButton href={settings.primaryCtas.join.href} label={settings.primaryCtas.join.label} />
        <SecondaryButton href={settings.primaryCtas.events.href} label={settings.primaryCtas.events.label} />
        <SecondaryButton
          href={settings.primaryCtas.opportunities.href}
          label={settings.primaryCtas.opportunities.label}
        />
      </div>
      <div class="mission-strip">
        <span>{settings.missionStripEn}</span>
        <strong>{settings.missionStripTe}</strong>
      </div>
    </div>

    <aside class="wordmark card" data-spotlight data-tilt data-reveal data-reveal-delay="1">
      <div class="crest-ring"></div>
      <p class="label">Together we belong</p>
      <img src={withBase(settings.logoPath)} alt={`${settings.fullName} logo`} class="hero-logo" />
      <h2>{settings.name}</h2>
      <p class="subhead">{settings.fullName}</p>
      <p class="description">{settings.taglineEn}</p>
      <div class="pulse-strip">
        <span>TSAB</span>
        <strong>Friendship, culture, and support.</strong>
      </div>
    </aside>
  </div>
</section>

<style>
  .hero-shell {
    align-items: stretch;
  }

  .hero-copy {
    min-height: clamp(28rem, 54vw, 38rem);
  }

  .hero-noise {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 18%, rgba(214, 163, 58, 0.12), transparent 24%),
      radial-gradient(circle at 82% 22%, rgba(21, 58, 120, 0.12), transparent 28%);
    pointer-events: none;
  }

  h1 {
    margin: 1rem 0 0;
    max-width: 10ch;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(3.05rem, 6vw, 5.9rem);
    line-height: 0.9;
    letter-spacing: -0.04em;
  }

  .hero-copy p {
    max-width: 58ch;
    margin-bottom: 0;
    color: var(--color-muted);
    font-size: 1.06rem;
  }

  .association-line {
    margin-top: 0.7rem;
    color: var(--color-brand-strong);
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .headline-te {
    margin-top: 0.35rem;
    color: var(--color-brand);
    font-size: 1.15rem;
    font-weight: 700;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 0;
    margin: 1rem 0 0;
    list-style: none;
  }

  .hero-tags li {
    padding: 0.42rem 0.72rem;
    border-radius: 999px;
    background: rgba(21, 58, 120, 0.08);
    color: var(--color-brand);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .mission-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.1rem;
    align-items: center;
    margin-top: 1.3rem;
    padding: 0.9rem 1rem;
    border-radius: 1.25rem;
    background: rgba(21, 58, 120, 0.08);
  }

  .mission-strip span {
    color: var(--color-brand);
    font-weight: 700;
  }

  .mission-strip strong {
    color: var(--color-accent);
    font-size: 1.02rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.2rem;
  }

  .wordmark {
    display: grid;
    align-content: start;
    gap: 0.8rem;
    padding: clamp(1.4rem, 2.2vw, 2rem);
    background:
      radial-gradient(circle at top right, rgba(214, 163, 58, 0.18), transparent 28%),
      linear-gradient(180deg, rgba(21, 58, 120, 0.05), rgba(255, 255, 255, 0.96));
  }

  .crest-ring {
    position: absolute;
    inset: 1.4rem 1.4rem auto auto;
    width: 5rem;
    aspect-ratio: 1;
    border-radius: 999px;
    border: 1px solid rgba(21, 58, 120, 0.16);
    background: radial-gradient(circle, rgba(214, 163, 58, 0.14), transparent 66%);
    pointer-events: none;
  }

  .label {
    margin: 0;
    color: var(--color-brand);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @keyframes heroLogoEntrance {
    0% {
      opacity: 0;
      transform: scale(0.8) translateY(20px);
    }
    100% {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @keyframes heroLogoFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .wordmark .hero-logo {
    width: 5rem;
    height: 5rem;
    object-fit: cover;
    border-radius: 1.1rem;
    box-shadow: 0 12px 28px rgba(13, 37, 83, 0.16);
    animation: 
      heroLogoEntrance 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards,
      heroLogoFloat 5s ease-in-out infinite alternate 1s;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.4s ease;
    will-change: transform, opacity;
  }

  .wordmark .hero-logo:hover {
    transform: scale(1.08) translateY(-4px);
    box-shadow: 0 18px 36px rgba(13, 37, 83, 0.22);
    animation-play-state: paused, paused;
  }

  .wordmark h2 {
    margin: 0;
    font-family: "Cormorant Garamond", serif;
    font-size: clamp(2.8rem, 8vw, 4.4rem);
    line-height: 0.9;
    color: var(--color-brand);
  }

  .subhead {
    margin: 0;
    font-weight: 700;
    line-height: 1.4;
  }

  .brand-te {
    margin: 0;
    color: var(--color-brand);
    font-weight: 700;
  }

  .description {
    margin: 0;
    color: var(--color-muted);
  }

  .pulse-strip {
    display: grid;
    gap: 0.2rem;
    margin-top: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(21, 58, 120, 0.1);
  }

  .pulse-strip span {
    color: var(--color-muted);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .pulse-strip strong {
    color: var(--color-brand);
    font-size: 1rem;
  }

  @media (max-width: 720px) {
    h1 {
      font-size: clamp(2.6rem, 12vw, 4.1rem);
      max-width: 8ch;
    }

    .association-line {
      margin-top: 0.55rem;
      font-size: 0.84rem;
    }

    .headline-te {
      font-size: 1rem;
    }

    .hero-copy p {
      font-size: 1rem;
    }

    .hero-tags {
      margin-top: 0.85rem;
    }

    .actions {
      gap: 0.65rem;
      margin-top: 1rem;
    }

    .mission-strip {
      margin-top: 1rem;
      padding: 0.8rem 0.9rem;
    }
  }
</style>
